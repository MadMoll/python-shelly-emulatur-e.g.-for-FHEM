defmod NotifyScriptShellyEmu notify Einspeisung:power.* {
Einspeisung:power.* {
  my $p = ReadingsVal("Einspeisung","power",0);
  my $tc = ReadingsVal("Einspeisung","total_consumption",0);
  my $tf = ReadingsVal("Einspeisung","total_feed",0);

  my $lock = "/tmp/shelly_emu.lock";

  # Wenn Lock existiert → Skript läuft bereits → NICHT starten
  if (-e $lock) {
    return;
  }

  # Lock setzen
  open(my $fh, '>', $lock);
  print $fh time();
  close($fh);

  # Python-Skript start power only
  #system("/usr/bin/python3 /home/scripts/shelly/NoLoopFHEMEmuShellyGen3.py $p &");
  # Python-Skript start all
  #system("/usr/bin/python3 /home/scripts/shelly/NoLoopFHEMEmuShellyGen3All.py $p $tc $tf &");

  # Lock nach kurzer Zeit entfernen
  # (damit das Skript beim nächsten echten Event wieder starten darf)
  my $cmd = "sleep 2 && rm -f $lock &";
  system($cmd);
}
